# Swarm usa el .env de la raíz del repo (mismo que 1-simple-compose y 2-blue-green-compose).
# Copiar a la raíz: cp deploy/2.5-swarm/.env.example .env
# Referencia de variables para la etapa Swarm.

# === Proyecto ===
PROJECT_NAME=mi-aplicacion
PROJECT_IMAGE=mi-aplicacion
PROJECT_VERSION=latest
PROJECT_PORT=5000

# Solo si quieres exponer el servicio: puerto en el host (ej. 5050). El contenedor usa siempre PROJECT_PORT.
# PORTS=5000:5050

# === Réplicas ===
REPLICAS=2

# Tiempo de espera en el rolling update antes de detener la tarea antigua (start-first).
# Debe ser mayor que el arranque de la app + health check para no enviar tráfico a tareas no listas.
# Formato: 60s, 2m, etc. Por defecto 60s si no se define.
# UPDATE_DELAY=60s

# === Red (como en 1-simple-compose / 2-blue-green-compose) ===
# ensure-network-swarm.sh crea la overlay con este nombre (y opcionalmente NETWORK_SUBNET).
# Si ya usas NETWORK para bridge (simple-compose/blue-green), define NETWORK_SWARM para la overlay (ej. my-network-swarm).
NETWORK=my-network
# NETWORK_SWARM=my-network-swarm
# NETWORK_SUBNET=10.20.0.0/24

# CONTAINER_IP: en 1-simple-compose/2-blue-green-compose fija la IP del contenedor. En Swarm la IP estable es la
# VIP del servicio (asignada por Swarm, no configurable); CONTAINER_IP no se usa.

# === Health ===
HEALTH_PATH=/health

# === Env en el contenedor (como ENV_FILE en 2-blue-green-compose) ===
# Archivos .env adicionales, separados por coma. Rutas relativas = respecto a la raíz del proyecto.
# ENV_FILE=app/.env
