# === Proyecto ===
PROJECT_NAME=mi-aplicacion
PROJECT_IMAGE=mi-aplicacion
PROJECT_VERSION=latest
PROJECT_PORT=3000

# Prefijo opcional. Si se define, los contenedores se nombran {PREFIX}-{PROJECT_NAME}-...
# Ejemplo: PROJECT_PREFIX=rx → contenedores rx-mi-aplicacion-app-blue-1, rx-mi-aplicacion-nginx-blue-green
# PROJECT_PREFIX=rx

# Puerto(s) que nginx expone al host (formato host:80). Por defecto PROJECT_PORT:80.
# PORTS=5050:80

# === Red ===
# Red principal (la que recibe CONTAINER_IP).
# Prioridad: NETWORK > NETWORK_DEFAULT > primera de NETWORK_NAME.
# Se crea automáticamente si no existe (con NETWORK_SUBNET si se define).
# Al menos una de las tres variables debe estar definida.
NETWORK=my-network
NETWORK_DEFAULT=my-network
# NETWORK_SUBNET=172.28.0.0/16

# IP fija del contenedor nginx (dentro de NETWORK_SUBNET). generate-nginx-override.sh escribe el override.
# CONTAINER_IP=172.28.0.2

# Redes adicionales para nginx (separadas por coma). La red principal se excluye automáticamente.
# Útil cuando nginx necesita ser alcanzable desde otras redes (ej. un reverse proxy externo).
# Las redes listadas aquí deben existir como redes Docker externas.
# NETWORK_NAME=cubiko,otra-red

# === Health ===
HEALTH_PATH=/health

# === Env en contenedores (app-blue, app-green) ===
# Archivos .env adicionales, separados por coma. Rutas relativas = respecto a la raíz del proyecto.
# ENV_FILE=app/.env

# === Hosts adicionales (extra_hosts en app-blue y app-green) ===
# Variables HOST_* con formato hostname:ip. Se inyectan como extra_hosts en los contenedores de app.
# HOST_DB=db.local:172.20.0.2
# HOST_CACHE=cache.local:172.20.0.3

# === Snippet nginx (desde la imagen) ===
# Ruta dentro de la imagen al snippet.conf. En deploy/switch se extrae a deploy/2-blue-green-compose/projects/${PROJECT_NAME}/snippet.conf.
# PROJECT_NGINX_DIR=/app/nginx/snippet.conf
