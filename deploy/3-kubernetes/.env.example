# Variables específicas de Kubernetes (Etapa 3). Mismo .env que el resto del proyecto.
# Copiar a la raíz del repo: cp deploy/3-kubernetes/.env.example .env

# === Proyecto (compartidas con otras etapas) ===
PROJECT_NAME=mi-aplicacion
PROJECT_IMAGE=mi-aplicacion
PROJECT_VERSION=latest
PROJECT_PORT=5050
PORTS=5050:5050
HEALTH_PATH=/health

# === Archivos .env adicionales (comma-separated) ===
# ENV_FILE=.env-algo

# === Kubernetes ===
# Puerto NodePort del Service dentro del cluster (30000-32767)
K8S_NODE_PORT=30080

# Ruta a los manifests k8s del proyecto (relativa a la raiz). Si no clonas el repo, define K8S_IMAGE_PATH.
# K8S_PROJECT_DIR=app/k8s
# Ruta dentro de la IMAGEN donde esta la carpeta k8s (ej. /app/k8s). Si esta definido, en deploy-k8s y en
# switch-k8s RECREATE=1 se extrae de la imagen a deploy/3-kubernetes/projects/PROJECT_NAME (no hace falta clonar).
# K8S_IMAGE_PATH=/app/k8s

# Replicas por color (default 1; el HPA puede escalar entre HPA_MIN y HPA_MAX)
REPLICAS=1

# HPA: minimo y maximo de replicas por color (limite = no pasarse de presupuesto)
HPA_MIN_REPLICAS=1
HPA_MAX_REPLICAS=5
# Target de uso de CPU (%) para escalar (80 = escala si promedio > 80%)
HPA_CPU_PERCENT=80
