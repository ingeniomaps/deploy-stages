# Plantilla de variables para ejecución manual.
# Copiar a .env en la RAÍZ DEL REPO y ajustar: cp deploy/0-manual/.env.example .env
# run.sh carga primero ese .env de la raíz; opcionalmente puede cargar más archivos vía ENV_FILE.

# Ruta al código fuente del proyecto (opcional).
# - Relativa: se resuelve desde la raíz del repo (SCRIPT_DIR/../..).
#   Ej: PROJECT_SOURCE=app          → <repo>/app
#   Ej: PROJECT_SOURCE=services/api → <repo>/services/api
# - Absoluta: se usa tal cual.
#   Ej: PROJECT_SOURCE=/home/user/my-project
# Si no se define, se usa la raíz del repo.
# PROJECT_SOURCE=app

# Ruta al Dockerfile (opcional, relativa al directorio del proyecto resuelto).
# Ej: DOCKERFILE_PATH=docker/Dockerfile → <proyecto>/docker/Dockerfile
# Si no se define, se usa <proyecto>/Dockerfile.
# DOCKERFILE_PATH=Dockerfile

# Archivo docker-compose principal de desarrollo (opcional).
# Si se define y el servicio principal tiene `command: [...]`, run-manual usará ese comando
# en lugar del CMD del Dockerfile (útil para scripts de dev/hot-reload, p. ej. bun dev).
# Ruta relativa a PROJECT_SOURCE (directorio del proyecto resuelto) o absoluta.
# Ej (si PROJECT_SOURCE=app): DOCKER_COMPOSE_APP=docker-compose.dev.yml
# DOCKER_COMPOSE_APP=docker-compose.dev.yml

# Archivos .env adicionales a cargar (opcional, separados por coma).
# Rutas relativas a la raíz del repo o absolutas. Se cargan después del .env de la raíz.
# ENV_FILE=app/.env,.env.local

# Puerto de la app. Si no se define PORT pero sí PROJECT_PORT, run.sh exporta PORT=${PROJECT_PORT}.
# PROJECT_PORT=3000
