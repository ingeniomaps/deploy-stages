# Plantilla de variables para despliegue.
# Copiar a .env en la raíz del repo: cp deploy/1-simple-compose/.env.example .env

# Nombre de la aplicación (imagen Docker, prefijos de contenedores, etc.)
PROJECT_NAME=mi-aplicacion

# Ruta al código fuente del proyecto (opcional).
# - Relativa: se resuelve desde la raíz del repo.
#   Ej: PROJECT_SOURCE=app          → <repo>/app
#   Ej: PROJECT_SOURCE=services/api → <repo>/services/api
# - Absoluta: se usa tal cual.
#   Ej: PROJECT_SOURCE=/home/user/my-project
# Si no se define, se usa la raíz del repo como contexto de build.
# PROJECT_SOURCE=app

# Ruta al Dockerfile (opcional, relativa al directorio del proyecto resuelto).
# Ej: DOCKERFILE_PATH=docker/Dockerfile → <proyecto>/docker/Dockerfile
# Si no se define, se usa <proyecto>/Dockerfile.
# DOCKERFILE_PATH=Dockerfile

# Complemento del proyecto para deploy-simple (opcional). Ruta relativa al directorio del proyecto (PROJECT_SOURCE).
# Con PROJECT_SOURCE=app basta: docker-compose.prod.yml (no hace falta app/docker-compose.prod.yml).
# DOCKER_COMPOSE_APP=docker-compose.prod.yml
# DOCKER_COMPOSE_APP=docker-compose.dev.yml

# Puerto en el que escucha la app dentro del contenedor (expose)
PROJECT_PORT=3000

# Puertos a exponer en el host (formato host:contenedor, separados por comas). Solo se añaden si están definidos.
# PORTS=5000:3000,5050:8080

# Red Docker: si no existe se crea; si existe se usa como externa. ensure-network.sh lo aplica.
NETWORK=my-network
# NETWORK_SUBNET=172.28.0.0/16

# Opcional: IP fija del contenedor (debe estar dentro de NETWORK_SUBNET si lo usas)
# CONTAINER_IP=172.28.0.2

# Opcional: archivo(s) de env para el contenedor. generate-extra-hosts.sh añade env_file si:
# - Existe deploy/1-simple-compose/.env (se usa como .env), y/o
# - Defines ENV_FILE con la ruta a uno o más archivos (varias separadas por coma).
# ENV_FILE=/ruta/a/otro.env
# ENV_FILE=app/.env,/etc/myapp/secrets.env

# Opcional: hosts extra en el contenedor. Cualquier variable HOST_* (formato hostname:ip).
# generate-extra-hosts.sh las lee y genera el override. Ejemplos:
# HOST_PRINCIPAL=db.local:172.20.0.2
# HOST_SECUNDARIO=api.internal:10.0.0.1
