# Variables por evolución de etapa. Detalle en deploy/<etapa>/.env.example

# --- Etapa 0 (run-manual) ---
# PROJECT_SOURCE=app
# DOCKERFILE_PATH=Dockerfile
# DOCKER_COMPOSE_APP=docker-compose.dev.yml
# ENV_FILE=app/.env,.env.local
# PROJECT_PORT=3000

# --- Etapa 1 (deploy-simple) ---
PROJECT_NAME=mi-aplicacion
PROJECT_PORT=3000
NETWORK=my-network
# PORTS=5000:3000,5050:8080
# NETWORK_SUBNET=172.28.0.0/16
# CONTAINER_IP=172.28.0.2
# ENV_FILE=app/.env
# HOST_DB=db.local:172.20.0.2

# --- Etapa 2 (deploy-bluegreen) ---
PROJECT_IMAGE=mi-aplicacion
PROJECT_VERSION=latest
# PROJECT_PREFIX=rx
# PORTS=5050:80
# NETWORK_DEFAULT=my-network
# NETWORK_NAME=cubiko,otra-red
HEALTH_PATH=/health
# PROJECT_NGINX_DIR=/app/nginx/snippet.conf

# --- Etapa 2.5 (deploy-swarm) ---
# REPLICAS=2
# UPDATE_DELAY=60s
# NETWORK_SWARM=my-network-swarm
